# LegacyOps Console — Environment example
#
# Copy to .env and adjust. The scaffold does NOT require any of these to
# run in synthetic mode. All values below are inert placeholders; never
# commit real secrets. See SECURITY.md for the full policy.

# ---------- API server ----------
# Port the Fastify API listens on. The web app dev server proxies /api to
# this port by default (see apps/web/vite.config.ts).
PORT=3001
NODE_ENV=development
# Log level for the Fastify logger. One of: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ---------- CORS ----------
# Comma-separated list of allowed origins for browser requests.
# Use "*" only for local development. In pilots, list the exact web origin
# (e.g. https://console.legacyops.example.com).
CORS_ORIGIN=http://localhost:5173

# ---------- Operational mode ----------
# Selects how LegacyOps talks to legacy systems. See docs/INTEGRATION_MODES.md
# for the full list: standalone | synthetic | legacy_overlay | workflow_wrapper
# | controlled_write_back | hybrid | progressive
LEGACYOPS_MODE=synthetic

# ---------- Siebel-like legacy adapter (only used when MODE != standalone) ----------
# These are placeholders. A real deployment points these at a sandbox (NOT
# production) Siebel-like endpoint and uses a read-only service account for
# the first pilot stages. See docs/PILOT_PLAYBOOK_SIEBEL.md.
SIEBEL_BASE_URL=http://localhost:9443/siebel
SIEBEL_USERNAME=readonly_service_account
SIEBEL_PASSWORD=replace_me_with_a_real_secret
SIEBEL_TIMEOUT_MS=8000
# Maximum number of retries for retriable integration errors (SBL-EAI-001, etc.)
SIEBEL_MAX_RETRIES=2

# ---------- Observability ----------
# Toggles legacy observability collection. Does NOT affect CRM operational
# metrics, which are always collected by the audit log.
OBSERVABILITY_ENABLED=true
# Optional: endpoint where /metrics would be scraped from. Not yet
# implemented; tracked gap in docs/ENTERPRISE_READINESS_GAP.md.
PROMETHEUS_SCRAPE_PATH=/metrics

# ---------- RBAC simulation (DEMO ONLY) ----------
# Default role when the x-legacyops-role header is absent. Real
# authentication (SSO/OIDC/SAML) is NOT implemented. See SECURITY.md and
# docs/SECURITY_NOTES.md.
LEGACYOPS_DEFAULT_ROLE=operator

# ---------- Security note ----------
# Never commit a .env file containing real credentials. The repository
# includes grep-based secret scanning in CI for common token prefixes
# (github_pat_, ghp_, AKIA, xoxb-). See SECURITY.md.
