# LegacyOps Console — Environment example
# Copy to .env and adjust. The scaffold does NOT require any of these to run.

# API
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins. "*" disables CORS in dev.
CORS_ORIGIN=http://localhost:5173

# Mode of operation. See docs/INTEGRATION_MODES.md
LEGACYOPS_MODE=standalone

# Legacy / Siebel-like adapter (only used when MODE=legacy_overlay or progressive_migration)
SIEBEL_BASE_URL=http://localhost:9443/siebel
SIEBEL_USERNAME=demo
SIEBEL_PASSWORD=demo
SIEBEL_TIMEOUT_MS=8000

# Observability
OBSERVABILITY_ENABLED=true

# Security note: no real secrets should ever be committed. This file is intentionally inert.
